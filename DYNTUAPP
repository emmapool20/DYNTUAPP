<script>
const USERS_KEY = 'dyntu_users';
const SESSION_KEY = 'dyntu_session';
function getUsers() { try { return JSON.parse(localStorage.getItem(USERS_KEY)) || {}; } catch { return {}; } }
function saveUsers(u) { localStorage.setItem(USERS_KEY, JSON.stringify(u)); }
function getSession() { try { return JSON.parse(localStorage.getItem(SESSION_KEY)); } catch { return null; } }
function saveSession(s) { localStorage.setItem(SESSION_KEY, JSON.stringify(s)); }
function clearSession() { localStorage.removeItem(SESSION_KEY); }

function showAuthScreen(id) { document.querySelectorAll('.auth-screen').forEach(s => s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function showToast(msg, success = false) { const t = document.getElementById('auth-toast'); t.textContent = msg; t.className = 'auth-toast' + (success ? ' success-toast' : '') + ' show'; setTimeout(() => t.classList.remove('show'), 3000); }
function togglePass(inputId, btn) { const input = document.getElementById(inputId); input.type = input.type === 'password' ? 'text' : 'password'; btn.textContent = input.type === 'password' ? '👁️' : '🙈'; }
function checkPasswordStrength() {
  const pass = document.getElementById('reg-password').value;
  const strength = document.getElementById('pass-strength'); const fill = document.getElementById('strength-fill'); const label = document.getElementById('strength-label');
  if (!pass) { strength.classList.remove('show'); return; } strength.classList.add('show');
  let score = 0; if (pass.length >= 6) score++; if (pass.length >= 10) score++; if (/[A-Z]/.test(pass)) score++; if (/[0-9]/.test(pass)) score++; if (/[^A-Za-z0-9]/.test(pass)) score++;
  const configs = [{w:'20%',color:'#FF4B4B',text:'😬 Muy débil',textColor:'#FF4B4B'},{w:'40%',color:'#C8102E',text:'🤔 Débil',textColor:'#C8102E'},{w:'60%',color:'#8B1A2F',text:'😐 Regular',textColor:'#8B1A2F'},{w:'80%',color:'#58595B',text:'😊 Buena',textColor:'#58595B'},{w:'100%',color:'#6b1224',text:'💪 Muy segura',textColor:'#6b1224'}];
  const c = configs[Math.min(score,4)]; fill.style.width = c.w; fill.style.background = c.color; label.textContent = c.text; label.style.color = c.textColor;
}
function validateRegField(id) {
  const input = document.getElementById(id); const error = document.getElementById(id+'-error'); const v = input.value.trim(); let valid = true;
