  .quiz-option.correct .quiz-option-letter { background: #2a7a2a; color: white; }
  .quiz-option.wrong { border-color: #CC2233; background: #fff0f0; }
  .quiz-option.wrong .quiz-option-letter { background: var(--red); color: white; }
  .quiz-option.disabled { pointer-events: none; }
  .quiz-feedback { display: none; border-radius: 14px; padding: 14px 16px; margin-top: 12px; font-size: 14px; font-weight: 700; align-items: center; gap: 10px; }
  .quiz-feedback.show { display: flex; animation: slideIn 0.2s ease; }
  .quiz-feedback.success { background: #f0fdf0; color: #1a5c1a; }
  .quiz-feedback.error { background: #fdeaec; color: #8B1A2F; }
  .feedback-icon { font-size: 24px; }
  .expert-ref { background: #fdf0f2; border-radius: 12px; padding: 10px 14px; font-size: 11px; color: #8B1A2F; font-weight: 700; margin-top: 12px; display: flex; align-items: center; gap: 6px; }
  .btn-complete { width: 100%; padding: 18px; border-radius: 16px; background: linear-gradient(135deg, #8B1A2F, #C8102E); color: white; font-family: 'Fredoka One', sans-serif; font-size: 18px; letter-spacing: 0.5px; border: none; cursor: pointer; box-shadow: 0 5px 0 #6b1224; transition: all 0.1s; margin-top: 4px; }
  .btn-complete:active { transform: translateY(3px); box-shadow: 0 2px 0 #6b1224; }
  .btn-complete:disabled { background: #ccc; box-shadow: 0 5px 0 #aaa; cursor: not-allowed; }
  .congrats-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; justify-content: center; align-items: flex-end; max-width: 390px; margin: 0 auto; left: 50%; transform: translateX(-50%); }
  .congrats-overlay.show { display: flex; }
  .congrats-card { background: white; border-radius: 28px 28px 0 0; padding: 32px 24px 40px; width: 100%; text-align: center; animation: slideUp 0.4s cubic-bezier(0.34,1.56,0.64,1); }
  @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
