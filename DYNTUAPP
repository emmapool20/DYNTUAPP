<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Dyntu – Tu profe de dinero 💸</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fredoka+One&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #8B1A2F;
    --green-dark: #6b1224;
    --green-light: #f5d0d8;
    --blue: #A81F35;
    --blue-dark: #6b1224;
    --yellow: #C8102E;
    --yellow-dark: #a00d25;
    --red: #CC2233;
    --purple: #7a1728;
    --orange: #A81F35;
    --bg: #f5f5f5;
    --card: #ffffff;
    --text: #2a2a2a;
    --text-light: #777;
    --border: #e0e0e0;
    --navbar-h: 72px;
    --upaep-red: #C8102E;
    --upaep-wine: #8B1A2F;
    --upaep-dark: #6b1224;
    --upaep-gray: #58595B;
    --upaep-light: #f5d0d8;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; justify-content: center; align-items: flex-start; }
  .app-shell { width: 100%; max-width: 390px; min-height: 100vh; background: var(--bg); position: relative; padding-bottom: calc(var(--navbar-h) + 16px); }
  .auth-shell { width: 100%; max-width: 390px; min-height: 100vh; background: var(--bg); display: flex; flex-direction: column; }
  .auth-screen { display: none; flex-direction: column; min-height: 100vh; }
  .auth-screen.active { display: flex; }
  .landing-hero { flex: 1; background: linear-gradient(160deg, #8B1A2F 0%, #C8102E 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 32px 40px; text-align: center; position: relative; overflow: hidden; }
  .landing-hero::before { content: ''; position: absolute; width: 300px; height: 300px; border-radius: 50%; background: rgba(255,255,255,0.08); top: -80px; right: -80px; }
  .landing-hero::after { content: ''; position: absolute; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,0.06); bottom: -40px; left: -60px; }
  .landing-mascot { font-size: 88px; margin-bottom: 16px; filter: drop-shadow(0 8px 24px rgba(0,0,0,0.15)); animation: float 3s ease-in-out infinite; position: relative; z-index: 1; }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  .landing-title { font-family: 'Fredoka One', sans-serif; font-size: 42px; color: white; letter-spacing: 1px; margin-bottom: 8px; position: relative; z-index: 1; }
  .landing-tagline { font-size: 16px; color: rgba(255,255,255,0.9); font-weight: 700; line-height: 1.5; position: relative; z-index: 1; }
  .landing-pills { display: flex; gap: 8px; margin-top: 24px; flex-wrap: wrap; justify-content: center; position: relative; z-index: 1; }
  .landing-pill { background: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.4); color: white; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 800; backdrop-filter: blur(4px); }
  .landing-actions { background: white; padding: 28px 24px 40px; border-radius: 28px 28px 0 0; box-shadow: 0 -4px 24px rgba(0,0,0,0.08); }
  .landing-actions h3 { font-family: 'Fredoka One', sans-serif; font-size: 20px; text-align: center; margin-bottom: 20px; color: var(--text); }
  .onboarding-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 500; justify-content: center; align-items: flex-end; max-width: 390px; margin: 0 auto; left: 50%; transform: translateX(-50%); }
  .onboarding-overlay.show { display: flex; }
  .onboarding-card { background: white; border-radius: 28px 28px 0 0; padding: 28px 24px 36px; width: 100%; animation: slideUp 0.4s cubic-bezier(0.34,1.56,0.64,1); }
  .onboarding-steps { display: flex; gap: 6px; justify-content: center; margin-bottom: 20px; }
  .onboarding-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: all 0.3s; }
  .onboarding-dot.active { background: var(--upaep-wine); width: 24px; border-radius: 4px; }
  .onboarding-emoji { font-size: 52px; text-align: center; display: block; margin-bottom: 12px; }
  .onboarding-title { font-family: 'Fredoka One', sans-serif; font-size: 22px; text-align: center; color: var(--text); margin-bottom: 8px; }
  .onboarding-desc { font-size: 14px; color: var(--text-light); font-weight: 600; text-align: center; line-height: 1.6; margin-bottom: 24px; }
  .onboarding-actions { display: flex; gap: 10px; }
  .btn-skip { padding: 14px 20px; border-radius: 14px; background: var(--bg); color: var(--text-light); font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 800; border: 2px solid var(--border); cursor: pointer; flex-shrink: 0; }
  .btn-next-tour { flex: 1; padding: 14px; border-radius: 14px; background: linear-gradient(135deg, #8B1A2F, #C8102E); color: white; font-family: 'Fredoka One', sans-serif; font-size: 16px; border: none; cursor: pointer; box-shadow: 0 4px 0 #6b1224; transition: all 0.1s; }
  .btn-next-tour:active { transform: translateY(2px); box-shadow: 0 2px 0 #6b1224; }
  .confirm-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 400; justify-content: center; align-items: center; max-width: 390px; margin: 0 auto; left: 50%; transform: translateX(-50%); padding: 24px; }
  .confirm-overlay.show { display: flex; }
  .confirm-card { background: white; border-radius: 24px; padding: 28px 24px; width: 100%; text-align: center; animation: popIn 0.25s cubic-bezier(0.34,1.56,0.64,1); }
  @keyframes popIn { from { transform: scale(0.85); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .confirm-emoji { font-size: 44px; display: block; margin-bottom: 10px; }
  .confirm-title { font-family: 'Fredoka One', sans-serif; font-size: 20px; color: var(--text); margin-bottom: 6px; }
  .confirm-msg { font-size: 14px; color: var(--text-light); font-weight: 600; margin-bottom: 20px; line-height: 1.5; }
  .confirm-actions { display: flex; gap: 10px; }
  .btn-confirm-cancel { flex: 1; padding: 14px; border-radius: 14px; background: var(--bg); color: var(--text); font-family: 'Fredoka One', sans-serif; font-size: 16px; border: 2px solid var(--border); cursor: pointer; transition: all 0.15s; }
  .btn-confirm-cancel:hover { background: #eee; }
  .btn-confirm-exit { flex: 1; padding: 14px; border-radius: 14px; background: var(--red); color: white; font-family: 'Fredoka One', sans-serif; font-size: 16px; border: none; cursor: pointer; box-shadow: 0 4px 0 #991a27; transition: all 0.1s; }
  .btn-confirm-exit:active { transform: translateY(2px); box-shadow: 0 2px 0 #991a27; }
  .btn-primary { width: 100%; padding: 18px; border-radius: 16px; background: linear-gradient(135deg, #8B1A2F, #C8102E); color: white; font-family: 'Fredoka One', sans-serif; font-size: 18px; letter-spacing: 0.5px; border: none; cursor: pointer; box-shadow: 0 5px 0 #6b1224; transition: all 0.1s; margin-bottom: 12px; }
  .btn-primary:active { transform: translateY(3px); box-shadow: 0 2px 0 #6b1224; }
  .btn-secondary { width: 100%; padding: 16px; border-radius: 16px; background: white; color: var(--blue); font-family: 'Fredoka One', sans-serif; font-size: 18px; border: 2.5px solid var(--blue); cursor: pointer; transition: all 0.15s; }
  .btn-secondary:hover { background: #fdeaec; }
  .btn-secondary:active { transform: scale(0.98); }
  .form-screen-header { background: white; padding: 16px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 2px solid var(--border); }
  .form-back-btn { width: 40px; height: 40px; border-radius: 12px; background: var(--bg); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 18px; flex-shrink: 0; transition: transform 0.1s; }
  .form-back-btn:active { transform: scale(0.9); }
  .form-screen-title { font-family: 'Fredoka One', sans-serif; font-size: 20px; color: var(--text); }
  .form-body { flex: 1; padding: 28px 24px; display: flex; flex-direction: column; }
  .form-icon { font-size: 52px; text-align: center; margin-bottom: 16px; }
  .form-title { font-family: 'Fredoka One', sans-serif; font-size: 24px; text-align: center; margin-bottom: 6px; }
  .form-subtitle { font-size: 14px; color: var(--text-light); font-weight: 600; text-align: center; margin-bottom: 28px; line-height: 1.5; }
  .input-group { margin-bottom: 16px; }
  .input-label { font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-light); margin-bottom: 6px; display: block; }
  .input-wrap { position: relative; }
  .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 18px; pointer-events: none; }
  .form-input { width: 100%; padding: 14px 14px 14px 44px; border-radius: 14px; border: 2.5px solid var(--border); font-family: 'Nunito', sans-serif; font-size: 15px; font-weight: 700; color: var(--text); background: white; outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
  .form-input:focus { border-color: #C8102E; box-shadow: 0 0 0 3px rgba(200,16,46,0.12); }
  .form-input.error { border-color: #CC2233; }
  .form-input.success { border-color: var(--upaep-wine); }
  .input-error { font-size: 12px; color: var(--red); font-weight: 700; margin-top: 5px; display: none; padding-left: 4px; }
  .input-error.show { display: block; }
  .toggle-password { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); cursor: pointer; font-size: 18px; background: none; border: none; padding: 0; line-height: 1; }
  .form-divider { display: flex; align-items: center; gap: 12px; margin: 16px 0; }
  .form-divider::before, .form-divider::after { content: ''; flex: 1; height: 2px; background: var(--border); border-radius: 1px; }
  .form-divider span { font-size: 12px; font-weight: 800; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.5px; }
  .btn-google { width: 100%; padding: 14px; border-radius: 14px; background: white; color: var(--text); font-family: 'Nunito', sans-serif; font-size: 15px; font-weight: 800; border: 2.5px solid var(--border); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: all 0.15s; }
  .btn-google:hover { background: #f8f8f8; border-color: #ccc; }
  .form-footer { text-align: center; margin-top: 20px; font-size: 14px; font-weight: 700; color: var(--text-light); }
  .form-link { color: var(--blue); cursor: pointer; font-weight: 900; text-decoration: none; background: none; border: none; font-family: inherit; font-size: inherit; padding: 0; }
  .form-link:hover { text-decoration: underline; }
  .form-submit-btn { width: 100%; padding: 18px; border-radius: 16px; background: linear-gradient(135deg, #8B1A2F, #C8102E); color: white; font-family: 'Fredoka One', sans-serif; font-size: 18px; border: none; cursor: pointer; box-shadow: 0 5px 0 #6b1224; transition: all 0.1s; margin-top: 8px; }
  .form-submit-btn:active { transform: translateY(3px); box-shadow: 0 2px 0 #6b1224; }
  .form-submit-btn:disabled { background: #ccc; box-shadow: 0 5px 0 #aaa; cursor: not-allowed; }
  .form-submit-btn.green-btn { background: linear-gradient(135deg, #8B1A2F, #C8102E); box-shadow: 0 5px 0 #6b1224; }
  .form-submit-btn.green-btn:active { box-shadow: 0 2px 0 #6b1224; }
  .password-strength { margin-top: 6px; display: none; }
  .password-strength.show { display: block; }
  .strength-bar { height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; margin-bottom: 4px; }
  .strength-fill { height: 100%; border-radius: 2px; transition: width 0.3s, background 0.3s; }
  .strength-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
  .header { background: var(--card); padding: 16px 20px 12px; border-bottom: 2px solid var(--border); position: sticky; top: 0; z-index: 100; }
  .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .logo { font-family: 'Fredoka One', sans-serif; font-size: 24px; color: var(--upaep-wine); letter-spacing: 1px; }
  .xp-badge { display: flex; align-items: center; gap: 6px; background: linear-gradient(135deg, #C8102E, #8B1A2F); color: white; font-weight: 800; font-size: 14px; padding: 6px 14px; border-radius: 20px; box-shadow: 0 3px 0 rgba(107,18,36,0.3); }
  .streak-badge { display: flex; align-items: center; gap: 4px; background: #fdf0f2; color: var(--upaep-wine); font-weight: 800; font-size: 14px; padding: 6px 12px; border-radius: 20px; border: 2px solid var(--upaep-wine); }
  .progress-label { display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: var(--text-light); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
  .progress-bar { background: var(--border); border-radius: 10px; height: 10px; overflow: hidden; }
  .progress-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #8B1A2F, #C8102E); transition: width 0.5s ease; position: relative; }
  .progress-fill::after { content: ''; position: absolute; right: -4px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; background: #8B1A2F; border: 3px solid white; border-radius: 50%; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
  .screen { display: none; padding: 20px; }
  .screen.active { display: block; }
  .welcome-banner { background: linear-gradient(135deg, #8B1A2F, #C8102E); border-radius: 20px; padding: 24px 20px; color: white; margin-bottom: 24px; position: relative; overflow: hidden; }
  .welcome-banner::before { content: '💸'; position: absolute; right: 16px; top: 12px; font-size: 52px; opacity: 0.3; }
  .welcome-banner h2 { font-size: 20px; font-weight: 900; margin-bottom: 6px; font-family: 'Fredoka One', sans-serif; letter-spacing: 0.5px; }
  .welcome-banner p { font-size: 13px; opacity: 0.9; font-weight: 600; }
  .section-title { font-family: 'Fredoka One', sans-serif; font-size: 18px; color: var(--text); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .lesson-path { display: flex; flex-direction: column; gap: 16px; }
  .lesson-node { display: flex; align-items: center; gap: 16px; cursor: pointer; position: relative; }
  .lesson-node::before { content: ''; position: absolute; left: 32px; top: 64px; width: 3px; height: 28px; background: var(--border); border-radius: 2px; }
  .lesson-node:last-child::before { display: none; }
  .lesson-icon { width: 64px; height: 64px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; border: 3px solid transparent; transition: transform 0.15s, box-shadow 0.15s; position: relative; }
  .lesson-icon.done { background: linear-gradient(135deg, var(--green-light), #f5d0d8); border-color: var(--upaep-wine); box-shadow: 0 4px 0 #6b1224; }
  .lesson-icon.active { background: linear-gradient(135deg, #f5d0d8, var(--yellow)); border-color: var(--yellow-dark); box-shadow: 0 4px 0 #6b1224; animation: pulse 2s infinite; }
  .lesson-icon.locked { background: #eee; border-color: #ccc; box-shadow: 0 4px 0 #bbb; filter: grayscale(1) opacity(0.5); }
  @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
  .lesson-node:active .lesson-icon { transform: scale(0.95); }
  .lesson-info { flex: 1; }
  .lesson-title { font-weight: 800; font-size: 15px; margin-bottom: 4px; }
  .lesson-sub { font-size: 12px; color: var(--text-light); font-weight: 600; }
  .lesson-status { font-size: 11px; font-weight: 800; padding: 3px 10px; border-radius: 20px; }
  .status-done { background: #f5d0d8; color: #6b1224; }
  .status-active { background: #f5d0d8; color: #8B1A2F; }
  .status-locked { background: #eee; color: #aaa; }
  .lesson-icon.done::after { content: '✓'; position: absolute; bottom: -6px; right: -6px; background: #8B1A2F; color: white; width: 22px; height: 22px; border-radius: 50%; font-size: 12px; font-weight: 900; display: flex; align-items: center; justify-content: center; border: 2px solid white; }
  .lesson-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .back-btn { width: 40px; height: 40px; border-radius: 12px; background: var(--card); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 18px; flex-shrink: 0; transition: transform 0.1s; }
  .back-btn:active { transform: scale(0.9); }
  .lesson-progress-bar { flex: 1; background: var(--border); border-radius: 10px; height: 10px; overflow: hidden; }
  .lesson-progress-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #C8102E, #8B1A2F); transition: width 0.4s; }
  .lesson-xp-counter { font-size: 13px; font-weight: 800; color: var(--upaep-wine); white-space: nowrap; }
  .lesson-card { background: var(--card); border-radius: 24px; padding: 24px 20px; box-shadow: 0 4px 16px rgba(0,0,0,0.06); border: 2px solid var(--border); margin-bottom: 16px; animation: slideIn 0.3s ease; }
  @keyframes slideIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .lesson-emoji { font-size: 48px; display: block; text-align: center; margin-bottom: 12px; }
  .lesson-card-title { font-family: 'Fredoka One', sans-serif; font-size: 22px; text-align: center; color: var(--text); margin-bottom: 14px; line-height: 1.2; }
  .content-block { border-radius: 14px; padding: 16px 18px; margin-bottom: 14px; font-size: 15px; line-height: 1.7; font-weight: 600; }
  .block-explain { background: #f8f8f8; border-left: 4px solid var(--upaep-gray); }
  .block-example { background: #fdf5f0; border-left: 4px solid var(--upaep-red); }
  .block-tip { background: #fdf0f2; border-left: 4px solid var(--upaep-wine); }
  .block-label { font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; opacity: 0.6; margin-bottom: 6px; }

  /* ── VIDEO YOUTUBE EMBED ── */
  .video-embed-wrap {
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 14px;
    position: relative;
    background: #000;
    border: 2px solid var(--border);
  }
  .video-embed-label {
    background: var(--upaep-wine);
    color: white;
    font-size: 10px;
    font-weight: 900;
    padding: 4px 10px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .video-embed-label span { opacity: 0.8; font-weight: 700; font-size: 11px; text-transform: none; letter-spacing: 0; }
  .video-iframe-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
  }
  .video-iframe-container iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
    display: block;
  }

  .quiz-section { margin-top: 4px; }
  .quiz-question { font-weight: 800; font-size: 15px; margin-bottom: 12px; color: var(--text); }
  .quiz-options { display: grid; gap: 10px; }
  .quiz-option { background: var(--card); border: 2.5px solid var(--border); border-radius: 14px; padding: 14px 16px; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.15s; text-align: left; display: flex; align-items: center; gap: 10px; }
  .quiz-option-letter { width: 28px; height: 28px; border-radius: 8px; background: var(--border); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 900; flex-shrink: 0; transition: all 0.15s; }
